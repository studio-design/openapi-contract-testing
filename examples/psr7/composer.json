{
    "name": "studio-design/gesso-psr7-example",
    "description": "Runnable PSR-7 example for studio-design/gesso.",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.3",
        "guzzlehttp/psr7": "^2.7",
        "studio-design/gesso": "@dev"
    },
    "autoload-dev": {
        "psr-4": {
            "Examples\\Psr7\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../..",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
