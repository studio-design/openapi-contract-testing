{
    "openapi": "3.0.3",
    "info": {
        "title": "Body validator throws",
        "version": "1.0.0"
    },
    "paths": {
        "/items/{id}": {
            "post": {
                "operationId": "createItem",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "pattern": "[unterminated"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "ok",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "pattern": "[unterminated"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
