                            "X-RateLimit-Remaining": {
                                "schema": { "type": "integer", "minimum": 0 }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": ["id"],
                                    "properties": {
                                        "id": { "type": "integer" }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
