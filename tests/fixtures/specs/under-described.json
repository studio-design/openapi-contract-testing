{
  "openapi": "3.0.3",
  "info": { "title": "Strict required fixture", "version": "1.0.0" },
  "paths": {
    "/signed-url": {
      "put": {
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "expires":    { "type": "integer" },
                    "signed_url": { "type": "string" },
                    "url":        { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/projects/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id":         { "type": "string" },
                    "name":       { "type": "string" },
                    "created_at": { "type": "string", "format": "date-time" }
                  },
                  "required": ["id", "name"]
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "type": "object", "required": ["id"], "properties": { "id": { "type": "string" } } },
                    { "type": "object", "properties": { "total": { "type": "integer" }, "currency": { "type": "string" } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id":   { "type": "string" },
                    "name": { "type": "string" }
                  },
                  "required": ["id", "name"]
                }
              }
            }
          }
        }
      }
    },
    "/scalar": {
      "get": {
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string" }
                    },
                    "required": ["id"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/either-shape": {
      "get": {
        "responses": {
          "200": {
            "description": "anyOf top-level — descent stops; surfaces as unwalkable NOTE not drift",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    { "type": "object", "required": ["a"], "properties": { "a": { "type": "string" } } },
                    { "type": "object", "required": ["b"], "properties": { "b": { "type": "string" } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/either-shape-oneof": {
      "get": {
        "responses": {
          "200": {
            "description": "oneOf top-level — pinned parallel to /either-shape so a refactor adding oneOf descent fails loudly",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "type": "object", "required": ["a"], "properties": { "a": { "type": "string" } } },
                    { "type": "object", "required": ["b"], "properties": { "b": { "type": "string" } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/malformed-required": {
      "get": {
        "responses": {
          "200": {
            "description": "spec author bug — non-string in required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id":   { "type": "string" },
                    "name": { "type": "string" }
                  },
                  "required": ["id", 42, null]
                }
              }
            }
          }
        }
      }
    },
    "/teams/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "ok; nested object whose `created_at` is always returned but optional in spec",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id", "data"],
                  "properties": {
                    "id":   { "type": "string" },
                    "data": {
                      "type": "object",
                      "required": ["name"],
                      "properties": {
                        "name":       { "type": "string" },
                        "created_at": { "type": "string", "format": "date-time" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/catalog": {
      "get": {
        "responses": {
          "200": {
            "description": "ok; array of objects with per-item under-description",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["items"],
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["id"],
                        "properties": {
                          "id":         { "type": "string" },
                          "name":       { "type": "string" },
                          "created_at": { "type": "string", "format": "date-time" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/dict": {
      "get": {
        "responses": {
          "200": {
            "description": "ok; additionalProperties carries a schema with required — strict_required deliberately does NOT walk into additionalProperties",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["entries"],
                  "properties": {
                    "entries": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "required": ["id"],
                        "properties": {
                          "id":    { "type": "string" },
                          "label": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/deep": {
      "get": {
        "responses": {
          "200": {
            "description": "ok; allOf-rooted with nested meta.* and rows[*]",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "type": "object",
                      "required": ["meta"],
                      "properties": {
                        "meta": {
                          "type": "object",
                          "required": ["page"],
                          "properties": {
                            "page":  { "type": "integer" },
                            "total": { "type": "integer" }
                          }
                        }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "rows": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": ["id"],
                            "properties": {
                              "id":    { "type": "string" },
                              "label": { "type": "string" }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/nullable-object": {
      "get": {
        "responses": {
          "200": {
            "description": "ok; nullable object — a literal JSON null body validates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "nullable": true,
                  "properties": {
                    "id": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
