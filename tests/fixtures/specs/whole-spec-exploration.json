{
    "openapi": "3.2.0",
    "info": {
        "title": "Whole-spec exploration fixture",
        "version": "1.0.0"
    },
    "paths": {
        "/pets": {
            "get": {
                "operationId": "listPets",
                "tags": ["public", "pets"],
                "responses": {"200": {"description": "OK"}}
            },
            "post": {
                "operationId": "createPet",
                "tags": ["write", "pets"],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["name"],
                                "properties": {"name": {"type": "string"}}
                            }
                        }
                    }
                },
                "responses": {"201": {"description": "Created"}}
            },
            "head": {
                "operationId": "headPets",
                "tags": ["public", "pets"],
                "responses": {"200": {"description": "OK"}}
            },
            "additionalOperations": {
                "COPY": {
                    "operationId": "copyPets",
                    "tags": ["write", "pets"],
                    "responses": {"204": {"description": "Copied"}}
                }
            }
        },
        "/admin": {
            "get": {
                "operationId": "adminIndex",
                "tags": ["admin"],
                "deprecated": true,
                "responses": {"200": {"description": "OK"}}
            }
        },
        "/broken": {
            "put": {
                "operationId": "brokenUpdate",
                "tags": ["write"],
                "requestBody": {
                    "required": true,
                    "content": {"application/json": {}}
                },
                "responses": {"204": {"description": "Updated"}}
            }
        }
    }
}
